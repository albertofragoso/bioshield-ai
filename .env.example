# BioShield AI — Environment Variables
# Copy this file to .env and fill in the actual values

# ===== Application =====
APP_NAME=BioShield AI
DEBUG=false

# ===== Database =====
# Development: sqlite:///./bioshield.db
# Production: postgresql://user:password@localhost:5432/bioshield
DATABASE_URL=sqlite:///./bioshield.db

# ===== Authentication (JWT) =====
# Use a strong random string in production (min 32 chars)
# Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Encryption (AES-256) =====
# Must be exactly 32 bytes (256 bits) for AES-256
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then convert to 32 ASCII bytes for direct use
# For development, use: "dev-aes-key-32-bytes-change-this!"
AES_KEY=dev-aes-key-32-bytes-change-this!

# ===== Google Gemini API =====
# Get your API key from: https://ai.google.dev/gemini-api
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ===== ChromaDB Vector Store =====
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=bioshield_ingredients

# ===== Embeddings Fallback =====
# If Gemini API is unavailable, fall back to local BGE-M3 embeddings
USE_LOCAL_EMBEDDINGS=false
BGE_MODEL_NAME=BAAI/bge-m3

# ===== Open Food Facts API =====
# Free public API for product data by barcode
OFF_BASE_URL=https://world.openfoodfacts.org/api/v2
OFF_TIMEOUT_SECONDS=10

# ===== CORS =====
# Allowed origins for frontend requests (comma-separated if multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
