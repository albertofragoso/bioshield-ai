# BioShield AI — Backend .env template
# Copia este archivo a .env y completa los valores para desarrollo local

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
APP_NAME = "BioShield AI"
DEBUG = false

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL = "sqlite:///./bioshield.db"
# Para PostgreSQL en producción: "postgresql://user:password@localhost/bioshield"

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
JWT_SECRET = "dev-secret-change-in-production"
JWT_ALGORITHM = "HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES = 30
JWT_REFRESH_TOKEN_EXPIRE_DAYS = 7

# ─────────────────────────────────────────────
# Encryption (AES-256)
# ─────────────────────────────────────────────
# Debe ser exactamente 32 bytes UTF-8. Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AES_KEY = "dev-aes-key-32-bytes-changethis!"

# ─────────────────────────────────────────────
# Gemini API (Vision + Embeddings)
# ─────────────────────────────────────────────
GEMINI_API_KEY = "your-gemini-api-key-here"
GEMINI_MODEL = "gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL = "models/gemini-embedding-001"

# ─────────────────────────────────────────────
# ChromaDB (Vector Store)
# ─────────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY = "./chroma_db"
CHROMA_COLLECTION_NAME = "bioshield_ingredients"

# ─────────────────────────────────────────────
# Embeddings — BGE-M3 local (primary, 1024-dim)
# GEMINI_API_KEY sigue siendo necesario para Vision OCR y copy generation,
# pero ya NO para embeddings cuando USE_LOCAL_EMBEDDINGS=true.
# Install: pip install torch --index-url https://download.pytorch.org/whl/cpu
# ─────────────────────────────────────────────
USE_LOCAL_EMBEDDINGS = true
BGE_MODEL_NAME = "BAAI/bge-m3"

# ─────────────────────────────────────────────
# Open Food Facts (READ — siempre habilitado)
# ─────────────────────────────────────────────
OFF_BASE_URL = "https://world.openfoodfacts.org/api/v2"
OFF_TIMEOUT_SECONDS = 10

# ─────────────────────────────────────────────
# Open Food Facts (WRITE — Fase 2, flujo contributivo)
# ─────────────────────────────────────────────
# Registra una cuenta en https://world.openfoodfacts.org y usa esas credenciales aquí
# OFF_CONTRIBUTOR_USER = nombre de usuario registrado en OFF
# OFF_CONTRIBUTOR_PASSWORD = contraseña del usuario
OFF_WRITE_BASE_URL = "https://world.openfoodfacts.org/cgi"
OFF_APP_NAME = "BioShieldAI"
OFF_APP_VERSION = "1.0"
OFF_CONTRIBUTOR_USER = ""
OFF_CONTRIBUTOR_PASSWORD = ""
OFF_CONTRIB_ENABLED = false
OFF_CONTRIB_TIMEOUT_SECONDS = 15
OFF_CONTRIB_SYNC_FOR_TESTS = false

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
ALLOWED_ORIGINS = ["http://localhost:3000"]
